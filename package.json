{
  "name": "@dszp/n8n-nodes-listmonk",
  "version": "0.1.0",
  "description": "n8n community node for Listmonk email & newsletter API",
  "keywords": [
    "n8n-community-node-package"
  ],
  "license": "MIT",
  "homepage": "",
  "author": {
    "name": "David Szpunar",
    "email": ""
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "engines": {
    "node": ">=18.10"
  },
  "packageManager": "pnpm@9.1.4",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint nodes credentials package.json --ext .ts,.json",
    "lint:fix": "eslint nodes credentials package.json --ext .ts,.json --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest --testPathPattern=e2e",
    "format": "prettier nodes credentials --write"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/listmonkApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/listmonk/listmonk.node.js"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.0",
    "n8n-workflow": "*",
    "nock": "^14.0.10",
    "openapi-types": "^12.1.3",
    "prettier": "^3.3.2",
    "ts-jest": "^29.4.1",
    "typescript": "^5.5.3",
    "yaml": "^2.4.5"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "@devlikeapro/n8n-openapi-node": "^0.1.0"
  }
}
